# Inspector 飞书应用 — 环境变量示例
# 复制为 .env 后填写（.env 不要提交 Git）

# ── 必填：Inspector（巡检员）应用凭证 ──
# 获取路径：飞书开放平台 → 你的应用 → 凭证与基础信息 → App ID / App Secret
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 群里 @ 巡检员 时匹配的名称（与飞书应用显示名一致）
INSPECTOR_AT_NAME=bot检查员

# ── 必填：测试群 chat_id（oc_ 开头）──
# 获取方法见 docs/GETTING_STARTED.md 第 3 步
NOTIFY_CHAT_ID=
TRIGGER_CHAT_IDS=

# 群内触发模式：ws = 长连接（推荐）
CHAT_TRIGGER_MODE=ws

# 启动时是否向 TRIGGER_CHAT_IDS 发就绪消息（1=是，0=否）
# SEND_READY_PING=1

# 强制接管已有 chat_trigger 进程（开发用）
# CHAT_TRIGGER_FORCE=1

# ── 可选：LLM 解释失败原因 ──
INSPECTOR_LLM_API_KEY=
INSPECTOR_LLM_BASE_URL=https://api.openai.com/v1
INSPECTOR_LLM_MODEL=gpt-4o-mini
# INSPECTOR_LLM_TEMPERATURE=0.3
